{
  "name": "agent-ui-workshop",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "download:shadcn": "curl -fsSL https://ui.shadcn.com/llms.txt -o ./docs/shadcn.md",
    "download:ai-elements": "curl -fsSL https://elements.ai-sdk.dev/llms.txt -o ./docs/ai-elements.md",
    "download:ai-sdk": "curl -fsSL https://ai-sdk.dev/llms.txt -o ./docs/ai-sdk.md",
    "download:pydantic-ai": "curl -fsSL https://ai.pydantic.dev/llms-full.txt -o ./docs/pydantic-ai.md",
    "download:chinook": "curl -fsSL https://github.com/lerocha/chinook-database/raw/master/ChinookDatabase/DataSources/Chinook_Sqlite.sqlite -o ./data/chinook.db",
    "prepare": "lefthook install && npm run download:chinook && npm run download:shadcn && npm run download:ai-elements && npm run download:ai-sdk && npm run download:pydantic-ai",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write",
    "test": "pnpm run test:frontend && pnpm run test:backend",
    "test:frontend": "vitest run",
    "test:backend": "cd agent && uv run pytest"
  },
  "dependencies": {
    "@radix-ui/react-use-controllable-state": "^1.2.2",
    "@streamdown/cjk": "^1.0.2",
    "@streamdown/code": "^1.0.3",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "ai": "^6.0.106",
    "class-variance-authority": "^0.7.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^0.576.0",
    "motion": "^12.34.4",
    "nanoid": "^5.1.6",
    "next": "16.1.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "shiki": "^4.0.1",
    "streamdown": "^2.3.0",
    "use-stick-to-bottom": "^1.1.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@taplo/cli": "^0.7.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "lefthook": "^2.1.2",
    "prettier": "^3.8.1",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "yaml-lint": "^1.7.0"
  }
}
