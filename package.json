{
  "name": "agent-ui-workshop",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "download:shadcn-llms-txt": "curl -fsSL https://ui.shadcn.com/llms.txt -o ./docs/shadcn-llms.txt",
    "download:ai-elements-llms-txt": "curl -fsSL https://elements.ai-sdk.dev/llms.txt -o ./docs/ai-elements-llms.txt",
    "download:ai-sdk-llms-txt": "curl -fsSL https://ai-sdk.dev/llms.txt -o ./docs/ai-sdk-llms.txt",
    "download:pydantic-ai-llms-txt": "curl -fsSL https://ai.pydantic.dev/llms-full.txt -o ./docs/pydantic-ai-llms.txt",
    "download:chinook": "curl -fsSL https://github.com/lerocha/chinook-database/raw/master/ChinookDatabase/DataSources/Chinook_Sqlite.sqlite -o ./data/chinook.db",
    "prepare": "lefthook install && npm run download:chinook && npm run download:shadcn-llms-txt && npm run download:ai-elements-llms-txt && npm run download:ai-sdk-llms-txt && npm run download:pydantic-ai-llms-txt",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write",
    "test": "pnpm run test:frontend && pnpm run test:backend",
    "test:frontend": "vitest run",
    "test:backend": "cd agent && uv run pytest"
  },
  "dependencies": {
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@taplo/cli": "^0.7.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "lefthook": "^2.1.2",
    "prettier": "^3.8.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "yaml-lint": "^1.7.0"
  }
}
